# PostgreSQL (keep Docker for now or use RDS)
RDS_USERNAME=postgres
RDS_PASSWORD=postgres
RDS_HOST=postgres
RDS_PORT=5432
RDS_DB_NAME=my_own_db

# AWS Region (must match where Bedrock is enabled)
AWS_DEFAULT_REGION=us-east-1

# DynamoDB (uses your AWS credentials automatically)
DYNAMODB_SESSION_TABLE_NAME=chat-sessions
DYNAMODB_ENDPOINT_URL=    # leave empty = uses real AWS

# S3
S3_BUCKET=sb3-tv-sales-metadata-700310640772
QUERY_PREFIX=queries/
# App flags
USE_MOCK_DBS=true
AUTH_DISABLED=true
USE_CONTEXT_AGENT=false
ENCODER_MODEL=TITAN_V1